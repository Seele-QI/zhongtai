# syntax=docker/dockerfile:1.7
# ────────────────────────────────────────────────────────────────
#  FastAPI 后端（视频生成 / ffmpeg 剪辑 / 积分账本）
#  对外暴露 8000，内部调用 RunningHub + DeepSeek + 火山方舟
# ────────────────────────────────────────────────────────────────

FROM python:3.13-slim AS runner
WORKDIR /app

# ── 1) ffmpeg ──
RUN apt-get update -qq \
    && apt-get install -y -qq --no-install-recommends ffmpeg \
    && rm -rf /var/lib/apt/lists/*

# ── 2) Python 依赖 ──
COPY requirements.txt ./
RUN pip install --no-cache-dir -r requirements.txt

# ── 3) 项目代码 ──
COPY main.py                     ./
COPY lib/                        lib/
COPY assets/                     assets/

# ── 4) 数据目录（Volume mount 会覆盖）──
ENV DATA_DIR=/data
ENV PYTHONUNBUFFERED=1
ENV PORT=8000
ENV HOST=0.0.0.0

RUN mkdir -p /data/video-cache/generated \
             /data/video-cache/manual-uploads \
             /data/video-postprocess \
    && chmod -R 755 /app /data

EXPOSE 8000

CMD ["sh", "-c", "python -m uvicorn main:app --host ${HOST:-0.0.0.0} --port ${PORT:-8000}"]
