# 复制为 .env.production 并填入真实值（不要提交到 git）
# 在 ECS 上执行：
#   cp .env.production.example .env.production
#   vi .env.production  ← 填入所有 true-key 的值
#   docker compose --env-file .env.production up -d

# ── 必填（缺一不可）──
DEEPSEEK_API_KEY=sk-xxx
RUNNINGHUB_API_KEY=xxx
EMAIL_HASH_SALT=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx  # python -c "import secrets; print(secrets.token_hex(32))"
CREDIT_ADMIN_ACCESS_KEY=xxxxxxxx  # python -c "import secrets; print(secrets.token_urlsafe(24))"

# ── 邮件（可选，开发期可跳过）──
RESEND_API_KEY=re_xxx
RESEND_FROM=AgentHub <onboarding@resend.dev>

# ── 基础 ──
APP_PUBLIC_BASE=http://你的服务器公网IP:3000
DEV_EMAIL_MODE=1
CORS_ALLOW_ORIGINS=*

# ── 可选 ──
# TIANAPI_KEY=
# ARK_API_KEY=
# ARK_ENDPOINT_ID=
# SHARE_BASE_URL=
# SHARE_API_TOKEN=
