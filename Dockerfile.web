# syntax=docker/dockerfile:1.7
# ────────────────────────────────────────────────────────────────
#  Next.js 前端（standalone 输出）
#  构建产物：.next/standalone（仅含运行时所需的 Node 依赖 + server bundle）
#  运行时由 standalone/server.js 提供 HTTP 服务，对外暴露 $PORT（默认 3000）
# ────────────────────────────────────────────────────────────────

# ── Stage 1: deps（pnpm + 所有依赖，含 devDependencies 用于 build）──
FROM node:22-alpine AS deps
WORKDIR /app

# 启用 pnpm 并安装依赖
RUN corepack enable && corepack prepare pnpm@latest --activate
COPY package.json pnpm-lock.yaml* pnpm-workspace.yaml* ./
RUN pnpm install --frozen-lockfile

# ── Stage 2: builder（构建 Next.js standalone）──
FROM node:22-alpine AS builder
WORKDIR /app
ENV NEXT_TELEMETRY_DISABLED=1

COPY --from=deps /app/node_modules ./node_modules
COPY . .

# 构建 standalone 输出（忽略 pre-existing TS 错误，确保 Zeabur web 服务能 build）
RUN corepack enable && corepack prepare pnpm@latest --activate \
    && NEXT_IGNORE_TYPE_ERRORS=1 pnpm run build

# ── Stage 3: runner（最终镜像，仅含运行所需）──
FROM node:22-alpine AS runner
WORKDIR /app
ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
ENV PORT=3000
ENV HOSTNAME=0.0.0.0

# standalone 自带 node_modules，但仍需复制 .next/static 与 public
COPY --from=builder --chown=nextjs:nodejs /app/.next/standalone ./
COPY --from=builder --chown=nextjs:nodejs /app/.next/static ./.next/static
COPY --from=builder --chown=nextjs:nodejs /app/public ./public

# 非 root 运行
RUN addgroup --system --gid 1001 nodejs \
    && adduser --system --uid 1001 nextjs \
    && mkdir -p .next \
    && chown nextjs:nodejs .next
USER nextjs

EXPOSE 3000

# standalone 模式自带 server.js
CMD ["node", "server.js"]
